export function getIconByKey(key: string): string {
  const item = DeviceIcons.find(i => i.key.toLowerCase() === key.toLowerCase());
  return item?.icon ?? '🏠';
}

export function getAllIconKeys(): string[] {
  return DeviceIcons.map(i => i.key);
}